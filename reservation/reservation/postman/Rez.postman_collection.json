        {
          "name": "Get latest reservation by recipient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.reservationId) {",
                  "  pm.environment.set('reservation_id', json.reservationId);",
                  "  if (json.resourceId) pm.environment.set('booked_resource_id', json.resourceId);",
                  "  console.info('reservation_id set to: ' + json.reservationId);",
                  "} else {",
                  "  console.warn('No reservation found for recipient_id=' + pm.environment.get('recipient_id'));",
                  "}"
                ],
