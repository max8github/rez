                  "console.info(\"calendar_id is: \"+ calendar_id);",
                  "console.info(\"resourceName is: \"+ resourceName);",
                  "",
                  "pm.variables.set(\"calendarId\", calendar_id);",
                  "pm.variables.set(\"resourceName\", resourceName);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
