        {
          "name": "Create QA booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function pad(n) { return String(n).padStart(2, '0'); }",
                  "var dt = new Date();",
                  "dt.setDate(dt.getDate() + 1);",
                  "dt.setHours(10, 0, 0, 0);",
                  "var bookingDateTime = dt.getFullYear() + '-' + pad(dt.getMonth() + 1) + '-' + pad(dt.getDate()) + 'T' + pad(dt.getHours()) + ':' + pad(dt.getMinutes()) + ':' + pad(dt.getSeconds());",
                  "var reservationId = pm.variables.replaceIn('{{$randomUUID}}').replace(/-/g, '').substring(0, 8);",
                  "var player1 = pm.variables.replaceIn('{{$randomFirstName}}');",
                  "var player2 = pm.variables.replaceIn('{{$randomFirstName}}');",
                  "var recipientId = 'postman:' + (pm.environment.get('botToken') || 'qa');",
                  "",
                  "pm.environment.set('booking_date_time', bookingDateTime);",
                  "pm.environment.set('reservation_id', reservationId);",
                  "pm.environment.set('player_1', player1);",
                  "pm.environment.set('player_2', player2);",
                  "pm.environment.set('recipient_id', recipientId);",
                  "",
                  "console.info('reservation_id: ' + reservationId);",
                  "console.info('booking_date_time: ' + bookingDateTime);",
                  "console.info('players: ' + player1 + ', ' + player2);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.reservationId) pm.environment.set('reservation_id', json.reservationId);",
                  "if (json && json.resourceId) pm.environment.set('booked_resource_id', json.resourceId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservationId\": \"{{reservation_id}}\",\n  \"dateTime\": \"{{booking_date_time}}\",\n  \"emails\": [\"{{player_1}}\", \"{{player_2}}\"],\n  \"resourceIds\": [\"{{resource_id_1}}\", \"{{resource_id_2}}\"],\n  \"recipientId\": \"{{recipient_id}}\"\n}"
            },
