          "name": "Create QA facility",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var suffix = pm.variables.replaceIn('{{$randomUUID}}').substring(0, 8);",
                  "var facilityName = 'QA Club ' + suffix;",
                  "var street = pm.variables.replaceIn('{{$randomStreetName}}');",
                  "var city = pm.variables.replaceIn('{{$randomCity}}');",
                  "var botToken = 'bot:local-test-' + suffix;",
                  "var adminUserId = String(Math.floor(Math.random() * 900000) + 100000);",
                  "",
                  "pm.environment.set('qa_suffix', suffix);",
                  "pm.environment.set('facilityName', facilityName);",
                  "pm.environment.set('street', street);",
                  "pm.environment.set('city', city);",
                  "pm.environment.set('botToken', botToken);",
                  "pm.environment.set('admin_user_id', adminUserId);",
                  "pm.environment.unset('facility_id');",
                  "pm.environment.unset('resource_id');",
                  "pm.environment.unset('resource_id_1');",
                  "pm.environment.unset('resource_id_2');",
                  "pm.environment.unset('reservation_id');",
                  "",
                  "console.info('QA suffix: ' + suffix);",
                  "console.info('QA botToken: ' + botToken);",
                  "console.info('QA admin_user_id: ' + adminUserId);"
