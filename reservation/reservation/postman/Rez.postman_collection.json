  "item": [
    {
      "name": "Facility",
      "item": [
        {
          "name": "Create facility",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var id = pm.response.text().replace(/\"/g, \"\");",
                  "pm.environment.set(\"facility_id\", id);",
                  "console.info(\"facility_id set to: \" + id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var facilityName = pm.variables.replaceIn('{{$randomLoremWord}}');",
                  "var street = pm.variables.replaceIn('{{$randomStreetName}}');",
                  "var city = pm.variables.replaceIn('{{$randomCity}}');",
                  "var timezone = pm.variables.get('timezone');",
                  "var botToken = pm.variables.get('botToken');",
                  "",
                  "console.info(\"Facility name is: \"+ facilityName);",
                  "console.info(\"Street is: \"+ street);",
                  "console.info(\"City is: \"+ city);",
                  "console.info(\"Timezone is: \"+ timezone);",
                  "console.info(\"Bot Token is: \"+ botToken);",
                  "",
                  "pm.variables.set(\"facilityName\", facilityName);",
                  "pm.variables.set(\"street\", street);",
                  "pm.variables.set(\"city\", city);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{facilityName}}\",\n  \"address\": {\n    \"street\": \"{{street}}\",\n    \"city\": \"{{city}}\"\n  },\n  \"resourceIds\": [],\n  \"timezone\": \"{{timezone}}\",\n  \"botToken\": \"{{botToken}}\",\n  \"adminUserIds\": []\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/facility/",
              "protocol": "{{protocol}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port}}",
              "path": [
                "facility",
                ""
              ]
            },
            "description": "Creates a facility; ID is auto-generated and returned. Stored in facility_id env var."
          },
          "response": []
        },
        {
          "name": "Get facility",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/facility/{{facility_id}}",
              "protocol": "{{protocol}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port}}",
              "path": [
                "facility",
                "{{facility_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Rename facility",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var newFacilityName = 'TC ' + pm.variables.replaceIn('{{$randomCity}}');",
                  "pm.variables.set(\"newFacilityName\", newFacilityName);",
                  "console.info(\"New facility name is: \"+ newFacilityName);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{newFacilityName}}\"\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/facility/{{facility_id}}/name",
              "protocol": "{{protocol}}",
              "host": [
                "{{host}}"
              ],
